modules = ["nodejs-20", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev & PORT=21427 pnpm --filter @workspace/portfolio run dev"
waitForPort = 21427

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 21427
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
build = ["bash", "-c", "pnpm --filter @workspace/portfolio run build && pnpm --filter @workspace/api-server run build"]
publicDir = "dist"
run = ["node", "--enable-source-maps", "./artifacts/api-server/dist/index.mjs"]
