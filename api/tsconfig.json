{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "noImplicitAny": true,
    "lib": ["es2022"],
    "types": ["node"],
    "paths": {
      "@workspace/db": ["../lib/db/src/index.ts"],
      "@workspace/db/*": ["../lib/db/src/*"]
    }
  },
  "include": ["."]
}
